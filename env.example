# Core Bot Configuration
# Скопируйте этот файл в .env и заполните значениями

# Telegram Bot Token (required) - получить у @BotFather
CORE_BOT_TOKEN=your_bot_token_here

# Database Core URL (optional, default: http://db-core:8000)
DB_CORE_URL=http://db-core:8000

# Payment Gateway URL (optional, default: http://payment-gateway:8000)
PAYMENT_GATEWAY_URL=http://payment-gateway:8000

# Payment Provider Token (optional) - получить у @BotFather для платежей
# Формат: 1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
# Инструкция: @BotFather → /mybots → выберите бота → Payments → Payment Provider
# В тестовом режиме (IS_TEST=true) токен не требуется
PAYMENT_PROVIDER_TOKEN=

# Test mode (optional) - установите true для тестового режима без реальных платежей
IS_TEST=true

# Admin Chat IDs (optional) - список chat ID администраторов через запятую
# Пример: ADMIN_CHAT_IDS=123456789,987654321
ADMIN_CHAT_IDS=

# Allow vacancy creation (optional) - установите true для разрешения создания вакансий
# Если false, кнопка "Создать вакансию" будет скрыта, а команда /create_vacancy будет недоступна
IS_CREATE=false

# Payment Gateway - Test mode (optional) - установите true для тестового режима без реальных платежей
# В тестовом режиме все платежи автоматически завершаются со статусом "success"
IS_TEST=false

# Payment Gateway - Robokassa
ROBOKASSA_MERCHANT_LOGIN=
ROBOKASSA_PASSWORD1=
ROBOKASSA_PASSWORD2=
ROBOKASSA_IS_TEST=true

# Мой налог (самозанятый)
MY_TAX_INN=
MY_TAX_API_KEY=

# Dadata API (для проверки компаний по ИНН)
# Получить API ключ: https://dadata.ru/api/
DADATA_API_KEY=

# Selfwork (pro.selfwork.ru) для оплаты от физ. лиц
# ВАЖНО: Теперь используется API init, поэтому статические URL больше не нужны
# (можно оставить пустыми или удалить)
SELFWORK_STANDARD_URL=
SELFWORK_BUSINESS_URL=
SELFWORK_PROFESSIONAL_URL=
# Секретный ключ для проверки webhook (настроить в личном кабинете Selfwork)
SELFWORK_WEBHOOK_SECRET=
# API ключ для Selfwork (ОБЯЗАТЕЛЬНО для создания платежей через API)
# Получить в личном кабинете pro.selfwork.ru
SELFWORK_API_KEY=your_selfwork_api_key_here
# Базовый URL для Selfwork API (опционально, по умолчанию: https://pro.selfwork.ru/merchant/v1)
# Согласно документации: POST https://pro.selfwork.ru/merchant/v1/init
SELFWORK_API_BASE_URL=https://pro.selfwork.ru/merchant/v1
# Домен вашего сайта для заголовков Origin и Referer (обязательно для запросов)
# ВАЖНО: Этот домен должен быть зарегистрирован в вашем аккаунте Selfwork!
# Укажите реальный домен вашего сайта, который зарегистрирован в Selfwork
# Если домен не зарегистрирован, вы получите ошибку "Не удалось найти магазин для указанного web-домена"
SELFWORK_MERCHANT_DOMAIN=https://your-domain.com

